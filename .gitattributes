# Normalize line endings to LF in the repository
* text=auto eol=lf

# Python files
*.py text eol=lf

# Docs and config
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.whl binary
